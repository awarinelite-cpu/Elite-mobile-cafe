// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function uid()     { return request.auth.uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid())).data.role == 'admin';
    }

    // ── users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAdmin();
    }

    // ── topics ────────────────────────────────────────────────
    match /topics/{topicId} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── orders ────────────────────────────────────────────────
    match /orders/{orderId} {
      // Client can read their own orders; admin reads all
      allow read:   if isAuth() && (
        resource.data.clientId == uid() || isAdmin()
      );
      // Client creates order
      allow create: if isAuth() && request.resource.data.clientId == uid();
      // Client or admin can update
      allow update: if isAuth() && (
        resource.data.clientId == uid() || isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
